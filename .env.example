# Copy to .env (or export these in your shell / Colab) to override defaults.
# Every variable is optional; the project ships with sensible defaults.

# --- Storage -----------------------------------------------------------------
# Root directory for all artefacts (model, checkpoints, logs, datasets, merged).
# Defaults: Drive on Colab, otherwise the repository root.
# FINAI_HOME=/content/drive/MyDrive/FinAI-Qwen

# --- Model -------------------------------------------------------------------
# NOTE: Qwen/Qwen2.5-8B does NOT exist. Use a real checkpoint (7B) or Qwen3-8B.
# FINAI_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
# FINAI_MODEL_REVISION=main
# FINAI_DTYPE=bfloat16
# FINAI_LOAD_IN_4BIT=true
# FINAI_COMPUTE_DTYPE=bfloat16
# FINAI_ATTN_IMPL=auto          # auto | flash_attention_2 | sdpa | eager
# FINAI_MAX_SEQ_LEN=4096
# FINAI_TRUST_REMOTE_CODE=false

# --- Generation --------------------------------------------------------------
# FINAI_MAX_NEW_TOKENS=1024
# FINAI_TEMPERATURE=0.7
# FINAI_TOP_P=0.8
# FINAI_TOP_K=20
# FINAI_REPETITION_PENALTY=1.05
# FINAI_SYSTEM_PROMPT=You are FinAI, a helpful financial assistant.

# --- Training ----------------------------------------------------------------
# FINAI_RUN_NAME=finai-qlora
# FINAI_DATASET=data/samples/alpaca_sample.jsonl
# FINAI_DATASET_FORMAT=auto
# FINAI_EPOCHS=3
# FINAI_MAX_STEPS=-1
# FINAI_TRAIN_BS=2
# FINAI_GRAD_ACCUM=8
# FINAI_LR=2e-4
# FINAI_LORA_R=16
# FINAI_LORA_ALPHA=32
# FINAI_LORA_DROPOUT=0.05
# FINAI_SAVE_TOTAL_LIMIT=3
# FINAI_SEED=42

# --- Logging -----------------------------------------------------------------
# FINAI_LOG_LEVEL=INFO
